# ==========================================================
# backend/.env.example
#
# Variables de entorno para el backend DINA
#
# INSTRUCCIONES:
#   1. Copiá este archivo a .env
#   2. Completá los valores
#   3. NUNCA subas .env a GitHub (ya está en .gitignore)
#
# En Cloud Run estas variables se configuran en la consola GCP
# o con el comando gcloud run deploy --set-env-vars
# ==========================================================

# --- Google Cloud Storage ---
# Nombre del bucket donde están los archivos .din, índices y diagnósticos
DINAS_BUCKET=nombre-de-tu-bucket

# Prefijo dentro del bucket (puede estar vacío si los archivos están en la raíz)
DINAS_GCS_PREFIX=interfaz_dinas

# --- Google Cloud Project ---
# Necesario para acceder a Secret Manager
GOOGLE_CLOUD_PROJECT=tu-project-id

# --- OpenAI ---
# Nombre del secret en GCP Secret Manager que contiene la API key
# Si no usás Secret Manager, podés poner la key directamente acá (solo para desarrollo local)
OPENAI_SECRET_NAME=OPENAI_API_KEY
# OPENAI_API_KEY=sk-...    # Solo para desarrollo local, nunca en producción

# --- CORS ---
# Orígenes permitidos separados por coma
# En desarrollo: localhost:3000 (Next.js) + localhost:8501 (Streamlit viejo)
# En producción: la URL de tu frontend en Cloud Run
CORS_ORIGINS=http://localhost:3000,http://localhost:8501
# CORS_ORIGINS=https://tu-frontend-abc123-uc.a.run.app
