# ==========================================================
# .gitignore — plataforma-dina
# ==========================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# --- Entornos virtuales ---
.venv/
venv/
env/
ENV/

# --- Variables de entorno (NUNCA subir) ---
.env
.env.local
.env.production
*.env

# --- Archivos temporales de datos ---
/tmp/
*.din
*.niv
din_index.parquet
din_index.csv
niv_index.parquet
snapshot.parquet

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Node.js / Next.js ---
node_modules/
.next/
out/
frontend/.next/
frontend/node_modules/
frontend/out/

# --- Logs ---
*.log
logs/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# --- Google Cloud ---
*.json
!package.json
!tsconfig.json
!next.config.js
# (los archivos de credenciales GCP son JSON y no deben subirse)
service-account-*.json
gcp-credentials*.json
