# ==========================================================
# .env.example — Plataforma DINA
# Copiá este archivo a .env y completá los valores.
# NUNCA subas .env a GitHub.
# ==========================================================

# Google Cloud Storage
DINAS_BUCKET=nombre-de-tu-bucket
DINAS_GCS_PREFIX=interfaz_dinas

# Google Cloud Project (para Secret Manager)
GOOGLE_CLOUD_PROJECT=tu-project-id

# OpenAI (nombre del secret en GCP Secret Manager)
OPENAI_SECRET_NAME=OPENAI_API_KEY
# Para desarrollo local podés poner la key directamente:
# OPENAI_API_KEY=sk-...

# CORS (Frontend URL)
# En desarrollo: localhost:3000
# En producción: URL del frontend en Cloud Run
CORS_ORIGINS=http://localhost:3000

# Credenciales GCP para desarrollo local
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/tu/service-account.json
