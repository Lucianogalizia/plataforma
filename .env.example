# ==========================================================
# .env.example — Plataforma DINA
# Copiá este archivo a .env y completá los valores.
# NUNCA subas .env a GitHub.
# ==========================================================

# ── Google Cloud Storage ───────────────────────────────────
DINAS_BUCKET=nombre-de-tu-bucket
DINAS_GCS_PREFIX=interfaz_dinas

# ── Google Cloud Project ───────────────────────────────────
GOOGLE_CLOUD_PROJECT=tu-project-id

# ── OpenAI ─────────────────────────────────────────────────
OPENAI_SECRET_NAME=OPENAI_API_KEY
# Para desarrollo local podés poner la key directamente:
# OPENAI_API_KEY=sk-...

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Credenciales GCP (solo desarrollo local) ───────────────
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/tu/service-account.json

# ── RRHH — PostgreSQL ──────────────────────────────────────
# Desarrollo local (docker-compose levanta postgres automáticamente)
RRHH_DB_HOST=localhost
RRHH_DB_PORT=5432
RRHH_DB_NAME=dina_rrhh
RRHH_DB_USER=dina
RRHH_DB_PASSWORD=dina_local

# Producción (Cloud SQL via socket o URL completa)
# RRHH_DATABASE_URL=postgres://user:pass@/dina_rrhh?host=/cloudsql/PROJECT:REGION:INSTANCE
